# Public origin of the app (no path). Used for OAuth redirect base.
# Local dev: use the SAME host:port you open in the browser, e.g. http://localhost:3000
# If Next chose another port, use that port in AUTH_URL and in Google Cloud redirect URIs.
# IMPORTANT: Do not set this to your Vercel URL while testing on localhost — that causes
# Error 400 redirect_uri_mismatch. For local testing, use http://localhost:PORT or remove
# AUTH_URL / NEXTAUTH_URL so the app uses the current request host.
# Production (Vercel): AUTH_URL=https://your-project.vercel.app
#AUTH_URL=http://localhost:3000
#
# In Google Cloud Console > OAuth 2.0 Client > Authorized redirect URIs, add EXACTLY:
#   <AUTH_URL or local origin>/api/auth/callback/google
# e.g. http://localhost:3000/api/auth/callback/google
# Authorized JavaScript origins: same origin only, e.g. http://localhost:3000
# Required for NextAuth. Or use NEXTAUTH_SECRET (same value).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Cloud (same project as the OAuth client id above):
# - Enable “Google Drive API” and “Photos Picker API” (APIs & services → Library). The old
#   “Photos Library API” / photoslibrary.readonly flow for browsing the whole library is not used.
# - OAuth consent screen → add scope
#   https://www.googleapis.com/auth/photospicker.mediaitems.readonly
#   (add custom scope if the picker does not appear in the short list), then republish the app.
# - If the app is in Testing, add your Google account under Test users on the consent screen.
# - After scope changes: https://myaccount.google.com/permissions — remove this app — sign in
#   again so the token includes the new scope.

# Optional: cloud similarity (Gemini)
GEMINI_API_KEY=

# Optional: auto-align (Python sidecar). From repo root: `npm run dev:all` starts Next + sidecar, or
#   cd sidecar && pip install -r requirements.txt && python -m uvicorn main:app --host 127.0.0.1 --port 8765
#ALIGN_SERVICE_URL=http://127.0.0.1:8765
